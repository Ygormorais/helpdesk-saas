# Base URL do backend (API)
# Exemplo local (backend em :3000):
VITE_API_URL=http://localhost:3000/api

# Opcional: URL do Socket.IO (se diferente do backend)
# VITE_SOCKET_URL=http://localhost:3000

# Opcional: alias antigo (mantido por compatibilidade)
# VITE_BACKEND_URL=http://localhost:3000

# Google Sign-In (opcional)
# Crie um OAuth Client ID "Web application" no Google Cloud Console
# e use o mesmo client ID no backend.
VITE_GOOGLE_CLIENT_ID=
