# API
API_PORT=4010

# Postgres
DATABASE_URL=postgresql://jp:jp@localhost:5433/jp?schema=public

# Redis
REDIS_URL=redis://localhost:6380

# Queue
QUEUE_NAME=jobs

# Dead-letter queue
DLQ_NAME=jobs-dlq

# Outbox publisher
OUTBOX_POLL_MS=1000

# Logging
LOG_LEVEL=info

# OpenTelemetry (optional)
OTEL_ENABLED=false
OTEL_SERVICE_NAME=job-platform
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318

# S3 (optional - for report artifacts)
AWS_REGION=us-east-1
S3_BUCKET=
S3_ENDPOINT=
S3_FORCE_PATH_STYLE=false
